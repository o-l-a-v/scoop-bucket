{
    "##": [
        "Why here? I want multiple PowerShell versions side by side.",
        "Strategy for having multiple versions installed side by side:",
        "* Add all versions to PATH (env_add_path), because a shim (bin) does not carry over the icon.",
        "* Rename all versions but the current newest stable one to avoid naming conflict."
    ],
    "version": "7.6.0-rc.1",
    "description": "Latest PowerShell preview. Cross-platform automation and configuration tool/framework, known as Powershell Core, that works well with existing tools and is optimized for dealing with structured data.",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": "MIT",
    "architecture": {
        "32bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.6.0-rc.1/PowerShell-7.6.0-rc.1-win-x86.zip",
            "hash": "85ed19bdccc7ca48ea1ff2bc29aef74ad5f7738288c316807f4c46460d7f77d7"
        },
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.6.0-rc.1/PowerShell-7.6.0-rc.1-win-x64.zip",
            "hash": "fe32e8abb312c99be468f0c0b1c417cd3f9a6e85591729b1be2de24b426027fd"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.6.0-rc.1/PowerShell-7.6.0-rc.1-win-arm64.zip",
            "hash": "d49f5914d1ff248ecb5506133e218d79503edf848a55b43b399c8f48a09a2bc7"
        }
    },
    "pre_install": [
        "# Rename instead of shimming, as the shim will not show the app icon",
        "Rename-Item -Path \"$dir\\pwsh.exe\" -NewName \"pwshp.exe\"",
        "# Delete some included modules",
        "$ModulesToRemove = [string[]](",
        "    'Microsoft.PowerShell.PSResourceGet',",
        "    'PackageManagement',",
        "    'PowerShellGet'",
        ")",
        "$ModulesToRemove.ForEach{",
        "    $Path = [System.IO.Path]::Combine($dir, 'Modules', $_)",
        "    if ([System.IO.Directory]::Exists($Path)) {",
        "        info ('Removing included module \"{0}\".' -f $_)",
        "        $null = [System.IO.Directory]::Delete($Path, $true)",
        "    }",
        "}"
    ],
    "env_add_path": ".",
    "shortcuts": [
        [
            "pwshp.exe",
            "PowerShell Preview",
            "-WorkingDirectory ~"
        ],
        [
            "pwshp.exe",
            "PowerShell Preview -NoProfile",
            "-WorkingDirectory ~ -NoProfile"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/PowerShell/PowerShell/releases",
        "jsonpath": "$[?(@.prerelease == true)].tag_name",
        "regex": "v([\\w.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x86.zip"
            },
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-arm64.zip"
            }
        }
    }
}
