{
    "##": [
        "Why here?",
        "* libjxl/libjxl since v0.12.0 does not include jpegli anymore",
        "* google/jpegli has no releases or binaries",
        "I will change to using the dedicated JPEGLI repo in the future if releases with binaries are made available."
    ],
    "version": "0.11.2",
    "description": "jpegli JPEG codec (encoder and decoder)",
    "homepage": "https://github.com/google/jpegli",
    "license": "BSD-3-Clause",
    "notes": "You should install main/libjxl too.",
    "suggest": {
        "libjxl": "main/libjxl"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/libjxl/libjxl/releases/download/v0.11.2/jxl-x64-windows-static.zip",
            "hash": "97dc815bdd99ba243d8502050357342cf649251a5df069f8c3daee6828cbe0ce"
        },
        "32bit": {
            "url": "https://github.com/libjxl/libjxl/releases/download/v0.11.2/jxl-x86-windows-static.zip",
            "hash": "39f53943143468bb27f653dcfa7f6d2cf71a8b9fa14269de21d475a821002957"
        }
    },
    "extract_dir": "bin",
    "pre_install": [
        "Get-ChildItem -Path $dir -Filter '*.exe' |",
        "    Where-Object -Property 'Name' -NotIn 'cjpegli.exe', 'djpegli.exe' |",
        "    Remove-Item"
    ],
    "bin": [
        "cjpegli.exe",
        "djpegli.exe"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/libjxl/libjxl/releases",
        "jsonpath": "$[?(@.prerelease == false)].tag_name",
        "regex": "v(0\\.11\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/libjxl/libjxl/releases/download/v$version/jxl-x64-windows-static.zip"
            },
            "32bit": {
                "url": "https://github.com/libjxl/libjxl/releases/download/v$version/jxl-x86-windows-static.zip"
            }
        }
    }
}
